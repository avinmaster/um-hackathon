# Required — get from https://console.ilmu.ai
GLM_API_KEY=sk-...

# ILMU endpoint + model — do not change unless ILMU publishes a new URL.
GLM_BASE_URL=https://api.ilmu.ai/v1
GLM_MODEL=ilmu-glm-5.1

# Database — SQLite for dev, Postgres for demo.
DATABASE_URL=sqlite:///./var/dev.sqlite
# DATABASE_URL=postgresql+psycopg://opus:opus@localhost:5432/opus

# Uploaded files — "local" writes to STORAGE_PATH; "s3" reserved for future.
STORAGE_BACKEND=local
STORAGE_PATH=./var/uploads

APP_ENV=dev
LOG_LEVEL=INFO
