# Provider switch: "glm" (ILMU) or "openai". Whichever you pick must have its key set below.
AI_MODEL=glm

# GLM (ILMU) — required when AI_MODEL=glm. Get a key from https://console.ilmu.ai
GLM_API_KEY=sk-...
GLM_BASE_URL=https://api.ilmu.ai/v1
GLM_MODEL=ilmu-glm-5.1

# OpenAI — required when AI_MODEL=openai. Default model is gpt-4o-mini; override as needed.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Database — SQLite for dev, Postgres for demo.
DATABASE_URL=sqlite:///./var/dev.sqlite
# DATABASE_URL=postgresql+psycopg://opus:opus@localhost:5432/opus

# Uploaded files — "local" writes to STORAGE_PATH; "s3" reserved for future.
STORAGE_BACKEND=local
STORAGE_PATH=./var/uploads

APP_ENV=dev
LOG_LEVEL=INFO

# Comma-separated list of allowed browser origins. Vercel preview deploys
# under *.vercel.app are matched by regex automatically.
CORS_ORIGINS=http://localhost:3000

# Set to "true" on a fresh prod DB to seed Shah Alam + Menara Demo on boot.
SEED_ON_STARTUP=false
